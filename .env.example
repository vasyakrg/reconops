# Copy to .env and fill in. The compose file picks up everything from here.
# .env is gitignored — never commit secrets.

# ── Operator login ────────────────────────────────────────────────────────────
# The hub bcrypt-hashes the plaintext password at startup. If you'd rather
# hand out a pre-computed hash (e.g. for CI / config-management without ever
# storing the plaintext), set RECON_ADMIN_PASSWORD_HASH instead — it wins
# over RECON_ADMIN_PASSWORD when both are set. Generate a hash with:
#   docker compose run --rm --no-deps --entrypoint /usr/local/bin/recon-hub \
#     -e RECON_ADMIN_PASSWORD='strong-password' hub --mode gen-password-hash
RECON_ADMIN_USER=admin
RECON_ADMIN_PASSWORD=
# RECON_ADMIN_PASSWORD_HASH=

# ── LLM provider ──────────────────────────────────────────────────────────────
# Default backend is OpenRouter; any OpenAI-compatible endpoint works.
# Get a key at https://openrouter.ai/keys
RECON_LLM_API_KEY=
RECON_LLM_BASE_URL=https://openrouter.ai/api/v1

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to "true" if you front the hub with nginx terminating TLS so the
# session cookie gets the Secure flag honouring X-Forwarded-Proto.
RECON_BEHIND_TLS_PROXY=false

# Override published ports if 8080 / 8443 / 9443 collide on the host.
# Hub UI is fronted by nginx; HTTPS=8443 is the operator entry point,
# HTTP=8080 is just a 301 → HTTPS.
# RECON_HTTP_PORT=8080
# RECON_HTTPS_PORT=8443
# RECON_GRPC_PORT=9443

# CN baked into the auto-generated self-signed TLS cert on first nginx start.
# Set to your real hostname for non-localhost dev.
# RECON_TLS_CN=recon.local

# Quick install for new agents — drives /hosts "Quick install" form and the
# /install/agent.sh endpoint. RELEASE_REPO + GRPC_ENDPOINT must be set
# together; leave blank to disable the feature. Override the same fields
# in deploy/docker/hub.yaml `install:` if you prefer config files over env.
# RECON_INSTALL_RELEASE_REPO=https://github.com/vasyakrg/reconops
# RECON_INSTALL_GRPC_ENDPOINT=hub.example.com:9443
# RECON_INSTALL_VERSION=latest   # or a tag like "0.1.0"

# Build-time version stamping (shown in the sidebar / login footer).
# RECON_VERSION=0.1.0
# RECON_COMMIT=$(git rev-parse --short HEAD)
