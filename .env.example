# Copy to .env and fill in. The compose file picks up everything from here.
# .env is gitignored — never commit secrets.

# ── Operator login ────────────────────────────────────────────────────────────
# Generate the bcrypt hash with:
#   docker compose run --rm --entrypoint /usr/local/bin/recon-hub hub \
#     --mode gen-password-hash <<<"strong-password"
# (or once a binary is built locally:
#   RECON_ADMIN_PASSWORD='strong-password' ./bin/recon-hub --mode gen-password-hash)
RECON_ADMIN_USER=admin
RECON_ADMIN_PASSWORD_HASH=

# ── LLM provider ──────────────────────────────────────────────────────────────
# Default backend is OpenRouter; any OpenAI-compatible endpoint works.
# Get a key at https://openrouter.ai/keys
RECON_LLM_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Set to "true" if you front the hub with nginx terminating TLS so the
# session cookie gets the Secure flag honouring X-Forwarded-Proto.
RECON_BEHIND_TLS_PROXY=false

# Override published ports if 8080/9443 collide on the host.
# RECON_HTTP_PORT=8080
# RECON_GRPC_PORT=9443

# Build-time version stamping (shown in the sidebar / login footer).
# RECON_VERSION=0.1.0
# RECON_COMMIT=$(git rev-parse --short HEAD)
